# ─────────────────────────────────────────────────────────────────────────────
# Galahad — configuration. Copy to `.env` and fill in. NOTHING is hard-coded in
# the images; every secret lives here. `.env` is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── The operator ─────────────────────────────────────────────────────────────
# Your Telegram chat id (the ONLY human the agents will talk to).
# Find it: start any bot below, message it, read the container log for
# "telegram_intruder" — the id shown is yours. Then set it here.
OPERATOR_CHAT_ID=REPLACE_ME

# ── Telegram bots — one dedicated bot per agent (create via @BotFather) ───────
CHEF_TELEGRAM_BOT_TOKEN=REPLACE_ME
GUARDIAN_TELEGRAM_BOT_TOKEN=REPLACE_ME
TRAVELER_TELEGRAM_BOT_TOKEN=REPLACE_ME

# ── Brain — ANY OpenAI-compatible endpoint (provider-agnostic) ───────────────
# Examples:
#   Ollama Cloud : https://ollama.com/v1
#   Local Ollama : http://host.docker.internal:11434/v1
#   OpenAI       : https://api.openai.com/v1
#   OpenRouter   : https://openrouter.ai/api/v1
#   Together     : https://api.together.xyz/v1
LLM_BASE_URL=https://ollama.com/v1
LLM_API_KEY=REPLACE_ME

# Per-role model ids (override the built-in defaults). Use whatever your
# endpoint serves. These defaults assume Ollama Cloud.
CHEF_MODEL=gpt-oss:120b
GUARDIAN_MODEL=deepseek-v4-flash
TRAVELER_MODEL=deepseek-v4-pro

# ── Cadence ──────────────────────────────────────────────────────────────────
GUARDIAN_HEARTBEAT_MINUTES=5
TRAVELER_HEARTBEAT_MINUTES=30
NIGHT_START=22
NIGHT_END=6

# ── Guardian patrol thresholds (zero-token anomaly gates) ────────────────────
# Cross any of these on a patrol → immediate Telegram alert. Defaults shown.
DISK_WARN=80    # alert when a mount is at/above this % full
RAM_WARN=90     # alert when RAM used is at/above this %
LOAD_WARN=8     # reserved: load-average alert threshold
# GALAHAD_TZ is passed per-service; set your tz here if you want, e.g. Europe/Paris
# GALAHAD_TZ=UTC

# ── Shared workspace (host path the team surveys & builds in) ────────────────
# Absolute path recommended in production, e.g. /srv/galahad/workspace
WORKSPACE_HOST=./workspace

# ── Claude bridge (optional heavy-dev muscle) ────────────────────────────────
# Leave CLAUDE_BRIDGE_TOKEN empty to run the team WITHOUT the bridge.
# To enable: set a strong token + an Anthropic key, then:
#   docker compose --profile bridge up -d
CLAUDE_BRIDGE_URL=http://claude-bridge:8799
CLAUDE_BRIDGE_TOKEN=
BRIDGE_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=
