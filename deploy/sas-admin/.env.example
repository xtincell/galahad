# Sas Admin danhermes — secrets & câblage backend. chmod 600. JAMAIS dans git/wiki/danmem.
# Copier en .env, remplir, puis : docker compose up -d --build

# --- Signature des JWT Fable (généré par install.sh si CHANGE_ME) ---
SAS_JWT_SECRET=CHANGE_ME
SAS_AUDIENCE=danhermes-admin

# --- État interne (volume sas-data) ---
SAS_REVOKED_FILE=/data/revoked.json
SAS_AUDIT_FILE=/data/audit.jsonl

# --- Backends (hostnames = alias/nom de conteneur sur le réseau `coolify`) ---
# danmem : le front nginx danmem-gateway injecte lui-même le bearer DanMem -> inject "none".
DANMEM_URL=http://danmem-gateway:80

# wiki : WebDAV (Basic Auth).
WEBDAV_URL=http://webdav-gateway:80
WEBDAV_USER=
WEBDAV_PASS=

# radar : API maison (Bearer = RADAR_API_KEY du conteneur radar).
# Pas d'alias réseau stable : l'URL est le NOM de conteneur Coolify (suffixe de déploiement
# variable). RADAR_URL sert au trafic normal ; sur échec, le sas RE-RÉSOUT par le préfixe
# d'UUID Coolify (stable across redeploys) via la socket docker, et réessaie une fois.
RADAR_URL=http://k9ri1rzxbpgv55thw5j7vzum-161519766896:3000
RADAR_CONTAINER_PREFIX=k9ri1rzxbpgv55thw5j7vzum
RADAR_PORT=3000
RADAR_TOKEN=

# cockpit : Basic Auth (BASIC_AUTH_USER / BASIC_AUTH_PASS de l'app cockpit).
COCKPIT_URL=http://cockpit:3000
COCKPIT_USER=
COCKPIT_PASS=

# coolify : API v1 (Bearer). Port interne 8080 (nginx), pas 8000.
COOLIFY_URL=http://coolify:8080
COOLIFY_TOKEN=

# /exec : allowlist argv[0]. Seul `docker` existe dans le conteneur (socket montée) ;
# host/DB via `docker exec <conteneur> ...`.
SAS_EXEC_ALLOW=docker
